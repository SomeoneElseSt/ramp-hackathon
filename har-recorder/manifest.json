{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "Tama",
  "version": "0.4.2",
  "description": "Tama sits on your authenticated tabs, streams ambient activity to the local daemon, and surfaces active listeners as you work. Nothing leaves your machine.",
  "permissions": [
    "tabs",
    "storage",
    "downloads",
    "scripting",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tama",
    "default_popup": "src/popup/popup.html"
  }
}
