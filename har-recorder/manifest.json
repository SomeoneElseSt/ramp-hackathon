{
  "manifest_version": 3,
  "name": "Tama Agent",
  "version": "0.1.0",
  "description": "Give browser agents reflexes. Watches the realtime signals a site already emits and wakes an agent when something happens, at zero model cost while idle.",
  "permissions": [
    "tabs",
    "storage",
    "downloads",
    "scripting",
    "webNavigation",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tama Agent",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "*://*/*.pdf"
      ],
      "js": [
        "src/content/pet-overlay.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  }
}
