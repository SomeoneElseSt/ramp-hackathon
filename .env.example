# Copy to .env at the repo root and fill in. The daemon loads ../.env and ./.env.
OPENAI_API_KEY=sk-...
# Model for the perception fallback that indexes unfamiliar payload shapes.
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# --- daemon (optional overrides) ---
# WebSocket bridge port (CONTRACT.md freezes 8787).
REFLEX_WS_PORT=8787
# How often the daemon emits a baseline poll tick for the demo comparison (ms).
REFLEX_POLL_INTERVAL_MS=60000
# Max model-assisted extraction calls (un-indexed sites) before falling back to heuristic only.
REFLEX_EXTRACT_BUDGET=40
